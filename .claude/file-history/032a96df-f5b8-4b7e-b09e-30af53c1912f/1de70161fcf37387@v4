  face_close: "models/facedect/640/model.onnx"
  arcface:    "models/facerecognize/model.onnx"
  reid:       "models/reid/osnet_x0_25.onnx"
  person:     "models/person/yolov8n.onnx"

runtime:
  prefer_gpu: true

detect:
  face_wide_conf:  0.30
  face_wide_iou:   0.5
  face_close_conf: 0.35
  face_close_iou:  0.5
  person_conf:     0.3
  person_iou:      0.5

track:
  iou_weight:  0.6
  reid_weight: 0.4
  max_age:     30
  min_hits:    3
  reid_ema:    0.1

ptz:
  expand_ratio:    2.0       # 3D 定位框外扩比例（Layer C：从 1.5 调大到 2.0，留移动缓冲区）
  settle_diff_th:  2.0       # 帧差均值 < 此值视为稳图
  settle_timeout:  1.5       # 2 倍变焦球机稳图快，1.5 秒超时

capture:
  min_samples: 3
  max_samples: 5
  timeout:     4.0           # 从 3.0 延长到 4.0，给追踪修正留余量

  # ── Layer B：CAPTURE 阶段动态追踪修正 ──
  tracking:
    enabled: true
    safe_zone_ratio: 0.6       # 画面中心 60% 为安全区，人脸在此区域内不触发修正
    correction_settle: 0.5     # 小幅修正后的稳图等待（比全量 1.5s 短很多）
    max_corrections: 3         # 单人 CAPTURE 期间最多修正 3 次（防无限追）
    face_lost_kalman_ms: 500   # 人脸丢失后用 Kalman 预测位置的容忍时长（ms）
    face_lost_giveup_ms: 1200  # 人脸丢失超过此时长则放弃（ms）

recognize:
  match_th:  0.35
  reject_th: 0.20

reid:
  cross_preset_th: 0.5      # 跨预设位去重阈值

output:
  strangers_dir: "output/strangers"
  events_jsonl:  "output/events.jsonl"

log:
  level: "INFO"
  file:  "logs/app.log"
```

